generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Utilisateurs ──
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  plan             String    @default("free") // free | pro
  stripeCustomerId String?   @unique
  welcomeEmailSent Boolean   @default(false)
  usedPromotion    Boolean   @default(false)

  // Media Kit / Link-in-Bio
  slug             String?   @unique
  bio              String?
  location         String?
  website          String?
  instagram        String?
  tiktok           String?
  youtube          String?
  twitter          String?
  linkedin         String?
  rates            String?   // JSON string: [{ label, price }]
  mediaKitPublic   Boolean   @default(false)
  pageViews        Int       @default(0)

  accounts      Account[]
  sessions      Session[]
  brands        Brand[]
  collaborations Collaboration[]
  payments      Payment[]
  events        Event[]
  aiUsage       AiUsage[]
  contacts      Contact[]
  emailCampaigns EmailCampaign[]
  links         Link[]
  emailSync     EmailSync?
}

// ── NextAuth (obligatoire) ──
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ── Usage IA ──
model AiUsage {
  id        String   @id @default(cuid())
  date      String   // format YYYY-MM-DD
  count     Int      @default(0)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ── Marques ──
model Brand {
  id            String   @id @default(cuid())
  name          String
  contact       String?
  email         String?
  notes         String?
  paymentDelay  String?
  status        String   @default("Actif")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  collaborations Collaboration[]
  payments       Payment[]
}

// ── Collaborations ──
model Collaboration {
  id           String   @id @default(cuid())
  platform     String
  deliverables String
  status       String   @default("lead")
  deadline     DateTime?
  amount       Int      @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandId      String
  brand        Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  payments     Payment[]
}

// ── Paiements ──
model Payment {
  id          String   @id @default(cuid())
  amount      Int
  status      String   @default("pending")
  invoiceDate DateTime?
  dueDate     DateTime?
  paidDate    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandId     String
  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  collaborationId String?
  collaboration   Collaboration? @relation(fields: [collaborationId], references: [id], onDelete: SetNull)
}

// ── Événements calendrier ──
model Event {
  id        String   @id @default(cuid())
  title     String
  type      String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Contacts (base de données emails) ──
model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  tags      String?  // JSON string: ["vip", "marque", ...]
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  recipients EmailRecipient[]

  @@unique([userId, email])
}

// ── Campagnes email ──
model EmailCampaign {
  id        String    @id @default(cuid())
  subject   String
  body      String
  status    String    @default("draft") // draft | sent
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  recipients EmailRecipient[]
}

// ── Destinataires par campagne ──
model EmailRecipient {
  id         String    @id @default(cuid())
  email      String
  status     String    @default("pending") // pending | sent | failed
  sentAt     DateTime?

  campaignId String
  campaign   EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  contactId  String?
  contact    Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([campaignId, email])
}

// ── Liens (Link-in-Bio) ──
model Link {
  id        String   @id @default(cuid())
  title     String
  url       String
  emoji     String?
  position  Int      @default(0)
  active    Boolean  @default(true)
  clicks    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, position])
}

// ── Sync Gmail ──
model EmailSync {
  id            String    @id @default(cuid())
  lastSyncAt    DateTime?
  lastMessageId String?
  enabled       Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
